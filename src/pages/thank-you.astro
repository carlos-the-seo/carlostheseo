---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank You"
  description="Your message has been received. Carlos will be in touch within 1 business day."
>
  <section class="min-h-[80vh] flex items-center justify-center px-6 py-24">
    <div class="max-w-lg w-full text-center">

      <!-- Icon -->
      <div class="w-16 h-16 rounded-2xl bg-[#f97316]/10 border border-[#f97316]/20 flex items-center justify-center mx-auto mb-8">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Got it — I'll be<br />in touch.
      </h1>
      <p class="text-[#64748b] text-lg mb-10">
        Usually within 1 business day. In the meantime, take a look at how I work.
      </p>

      <!-- Next steps -->
      <div class="bg-[#0f0f1a] border border-[#1e1e30] rounded-2xl p-6 text-left mb-8 space-y-4">
        <p class="text-xs font-semibold text-[#334155] uppercase tracking-wider">While you wait</p>
        <a href="/services" class="flex items-center justify-between group py-2 border-b border-[#1e1e30]">
          <span class="text-sm text-[#94a3b8] group-hover:text-white transition-colors">See exactly what's included in each service</span>
          <span class="text-[#f97316] text-sm">→</span>
        </a>
        <a href="/about" class="flex items-center justify-between group py-2 border-b border-[#1e1e30]">
          <span class="text-sm text-[#94a3b8] group-hover:text-white transition-colors">Learn about my background and how I work</span>
          <span class="text-[#f97316] text-sm">→</span>
        </a>
        <a href="https://www.linkedin.com/in/carlos-morones/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-between group py-2">
          <span class="text-sm text-[#94a3b8] group-hover:text-white transition-colors">Connect on LinkedIn</span>
          <span class="text-[#f97316] text-sm">→</span>
        </a>
      </div>

      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-[#475569] hover:text-white transition-colors font-medium"
      >
        ← Back to home
      </a>

    </div>
  </section>
</Layout>
