---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: '◎',
    title: 'SEO Audits',
    description: 'Know exactly why you\'re not ranking — and what to fix first — with a multi-source diagnosis that doesn\'t guess.',
  },
  {
    icon: '⟳',
    title: 'Content Pipeline',
    description: 'A repeatable system that turns your expertise into search traffic without restarting from scratch every month.',
  },
  {
    icon: '{}',
    title: 'Schema & Technical SEO',
    description: 'Show up in AI Overviews and rich results your competitors haven\'t figured out how to get into yet.',
  },
  {
    icon: '◈',
    title: 'AI-Powered SEO Ops',
    description: 'Monitoring, alerts, and automated briefs that keep your SEO moving without the overhead of a full agency.',
  },
  {
    icon: '⊙',
    title: 'Local & Location SEO',
    description: 'Rank in every city and service area you operate — not just wherever your HQ is on Google Maps.',
  },
  {
    icon: '↗',
    title: 'Ongoing Monitoring',
    description: 'Ranking drops and technical issues get caught and flagged before your clients notice them before you do.',
  },
];

const differentiators = [
  {
    headline: 'You own the playbook',
    description: 'Every fix, pipeline, and strategy lives in documentation you can hand to anyone. No lock-in, no black box.',
  },
  {
    headline: 'Problems get caught early',
    description: 'Daily monitoring flags ranking drops, content gaps, and technical issues before they become expensive.',
  },
  {
    headline: 'Each piece builds on the last',
    description: 'Technical fixes lift content rankings. Content builds authority. Monitoring catches what slips. It\'s a system, not a service.',
  },
];

const proof = [
  'Went from a generic agency retainer to an SEO system that runs daily — and finally started ranking for the searches that bring in actual clients.',
  'Their location pages went from afterthoughts to their #1 source of inbound leads.',
  'For the first time, they knew exactly what was wrong with their SEO — and what to fix first. Rankings followed.',
];

const stackLogos = ['Ahrefs', 'Claude AI', 'Google Search Console', 'GA4', 'Search Atlas', 'Webflow', 'Sanity'];
---

<Layout
  title="SEO Systems + AI Pipelines"
  description="You don't need another agency. You need a system. I build the SEO infrastructure that keeps running long after most retainers expire."
>

  <!-- Hero -->
  <section class="relative pt-36 pb-28 px-6 overflow-hidden">
    <!-- Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#f97316]/8 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-20 left-1/4 w-[300px] h-[300px] bg-indigo-500/5 rounded-full blur-[80px] pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: Copy -->
        <div>
          <div class="inline-flex items-center gap-2 bg-[#f97316]/10 border border-[#f97316]/20 rounded-full px-4 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-[#f97316] animate-pulse"></span>
            <span class="text-xs font-medium text-[#f97316]">Available for new clients</span>
          </div>

          <h1 class="text-5xl md:text-6xl font-bold text-white leading-[1.06] tracking-tight mb-6">
            Stop buying SEO.<br />
            <span class="text-[#f97316]">Start building it.</span>
          </h1>

          <p class="text-lg text-[#64748b] leading-relaxed mb-10 max-w-lg">
            You don't need another agency. You need a system. I build the SEO infrastructure — content pipelines, technical fixes, daily monitoring — that keeps running long after most retainers expire.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 bg-[#f97316] hover:bg-[#ea6c0a] text-white font-semibold px-6 py-3.5 rounded-xl transition-colors text-sm"
            >
              Work With Me
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M2 7h10M8 3l4 4-4 4" />
              </svg>
            </a>
            <a
              href="/case-studies"
              class="inline-flex items-center justify-center gap-2 border border-[#1e1e30] hover:border-[#334155] text-[#64748b] hover:text-white font-semibold px-6 py-3.5 rounded-xl transition-colors text-sm"
            >
              See the Work
            </a>
          </div>
        </div>

        <!-- Right: Terminal card -->
        <div class="hidden lg:block">
          <div class="bg-[#0f0f1a] border border-[#1e1e30] rounded-2xl overflow-hidden shadow-2xl">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-[#1e1e30] bg-[#0a0a12]">
              <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
              <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
              <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
              <span class="ml-3 text-xs text-[#64748b] font-mono">sentinel — daily brief</span>
            </div>
            <div class="p-6 font-mono text-sm space-y-3">
              <p class="text-[#64748b]">$ sentinel run --clients all --date today</p>
              <p class="text-green-400">✓ 24 clients scanned</p>
              <p class="text-[#e2e8f0]">→ 3 ranking movements detected</p>
              <p class="text-[#e2e8f0]">→ 1 technical issue flagged</p>
              <p class="text-[#e2e8f0]">→ 2 content opportunities found</p>
              <p class="text-[#64748b] mt-2">Posting brief to Slack...</p>
              <p class="text-green-400">✓ Brief delivered — 8:31 AM</p>
              <div class="mt-4 pt-4 border-t border-[#1e1e30]">
                <p class="text-xs text-[#334155]">// Runs every morning before you open your laptop</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Tool Stack -->
  <section class="px-6 pb-20">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-semibold text-[#334155] uppercase tracking-widest text-center mb-6">
        Tools I actually use — named, not vague
      </p>
      <div class="flex flex-wrap items-center justify-center gap-2">
        {stackLogos.map((logo) => (
          <span class="border border-[#1e1e30] bg-[#0f0f1a] rounded-lg px-4 py-2 text-xs font-medium text-[#475569]">
            {logo}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Differentiators -->
  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 max-w-xl">
        <p class="text-xs font-semibold text-[#f97316] uppercase tracking-widest mb-3">Why it's different</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          Not a consultant.<br />An operator.
        </h2>
        <p class="text-[#64748b] mt-4">
          Most agencies produce reports. I build the infrastructure that runs the work.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {differentiators.map(({ headline, description }) => (
          <div class="bg-[#0f0f1a] border border-[#1e1e30] rounded-2xl p-8 hover:border-[#f97316]/25 transition-colors group">
            <div class="w-8 h-8 rounded-lg bg-[#f97316]/10 mb-6 flex items-center justify-center group-hover:bg-[#f97316]/20 transition-colors">
              <span class="text-[#f97316] text-sm">◆</span>
            </div>
            <h3 class="text-white font-semibold text-base mb-3">{headline}</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-xs font-semibold text-[#f97316] uppercase tracking-widest mb-3">Services</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">What I build for you</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.map(({ icon, title, description }) => (
          <div class="bg-[#0f0f1a] border border-[#1e1e30] rounded-2xl p-7 hover:border-[#f97316]/25 transition-colors group cursor-default">
            <span class="text-xl text-[#f97316]/70 mb-5 block font-mono group-hover:text-[#f97316] transition-colors">{icon}</span>
            <h3 class="text-white font-semibold text-base mb-2">{title}</h3>
            <p class="text-[#64748b] text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href="/services" class="text-sm text-[#475569] hover:text-[#f97316] transition-colors font-medium inline-flex items-center gap-1">
          View all services <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <p class="text-xs font-semibold text-[#f97316] uppercase tracking-widest mb-3">Results</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">What changes when it works</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {proof.map((quote) => (
          <div class="bg-[#0f0f1a] border border-[#1e1e30] rounded-2xl p-8">
            <div class="text-[#f97316] text-3xl font-serif mb-5 leading-none">"</div>
            <p class="text-[#94a3b8] text-sm leading-relaxed">{quote}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 pb-24">
    <div class="max-w-6xl mx-auto">
      <div class="relative bg-[#0f0f1a] border border-[#1e1e30] rounded-3xl px-8 md:px-20 py-20 text-center overflow-hidden">
        <!-- Subtle glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#f97316]/6 via-transparent to-indigo-500/4 pointer-events-none"></div>
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[200px] bg-[#f97316]/8 rounded-full blur-[60px] pointer-events-none"></div>

        <div class="relative">
          <p class="text-xs font-semibold text-[#f97316] uppercase tracking-widest mb-5">Let's build</p>
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 leading-tight">
            SEO that still runs<br />six months from now.
          </h2>
          <p class="text-[#64748b] mb-10 max-w-md mx-auto text-base leading-relaxed">
            Not a pitch — a real conversation about what's broken and what it takes to fix it properly.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 bg-[#f97316] hover:bg-[#ea6c0a] text-white font-semibold px-8 py-4 rounded-xl transition-colors"
          >
            Work With Me
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M2 7h10M8 3l4 4-4 4" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
