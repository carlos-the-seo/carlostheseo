---
const year = new Date().getFullYear();
---

<footer class="border-t border-[#1e1e30] mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <div class="md:col-span-2">
        <a href="/" class="text-white font-semibold text-lg tracking-tight">
          Carlos<span class="text-[#f97316]">Morones</span>
        </a>
        <p class="mt-3 text-sm text-[#64748b] max-w-xs leading-relaxed">
          SEO systems and AI pipelines built for businesses that want results, not reports.
        </p>
      </div>

      <div>
        <p class="text-xs font-semibold text-[#64748b] uppercase tracking-wider mb-4">Work</p>
        <ul class="space-y-3">
          {[
            { label: 'Services', href: '/services' },
            { label: 'Tools', href: '/tools' },
            { label: 'Case Studies', href: '/case-studies' },
          ].map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-[#64748b] hover:text-white transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold text-[#64748b] uppercase tracking-wider mb-4">Connect</p>
        <ul class="space-y-3">
          {[
            { label: 'Blog', href: '/blog' },
            { label: 'Contact', href: '/contact' },
            { label: 'LinkedIn', href: 'https://linkedin.com/in/carlosmorones', external: true },
          ].map(({ label, href, external }) => (
            <li>
              <a
                href={href}
                class="text-sm text-[#64748b] hover:text-white transition-colors"
                {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-[#1e1e30] pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[#64748b]">© {year} Carlos Morones. All rights reserved.</p>
      <p class="text-xs text-[#64748b]">carlosmorones.com</p>
    </div>
  </div>
</footer>
